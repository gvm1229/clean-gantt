# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth.js / NextAuth v5
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_TRUST_HOST=true

# OAuth providers (only supported login methods)
# Auth.js can infer these standard provider variables.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# MongoDB
# Local browser-created charts work without MongoDB, but signed-in persistence requires it.
MONGODB_URI=
MONGODB_DB=clean_gantt
MONGODB_APP_NAME=clean-gantt

# Optional observability
LOG_LEVEL=info
